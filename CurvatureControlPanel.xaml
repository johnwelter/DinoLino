<UserControl x:Class="DinoLino.Utilities.Modes.CurvatureControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- RadioButton that renders identically to a CheckBox -->
        <Style x:Key="CheckBoxRadioButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border Width="13" Height="13"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True"
                                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                                    <Path x:Name="CheckMark"
                                          Margin="1"
                                          SnapsToDevicePixels="False"
                                          Data="M 0,4 L 3,7 L 8,0"
                                          Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          StrokeThickness="2"
                                          Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="4,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckMark"
                                        Property="Stroke"
                                        Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <StackPanel x:Name="UI_CurvatureOutputs">
        <RadioButton Content="Circular Arc" GroupName="Curve" Checked="CircularArc_Checked"
                     MinHeight="25" FontWeight="Bold"/>
        <StackPanel Visibility="{Binding IsCircularArcSelected, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Central Angle:"/>
                <Label Content="{Binding CentralAngleResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Chord-Arc Ratio:"/>
                <Label Content="{Binding ChordArcRatioResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Rise-Span Ratio:"/>
                <Label Content="{Binding AspectRatioResult}" Width="175"/>
            </StackPanel>
        </StackPanel>

        <RadioButton Content="Parabolic Arc" GroupName="Curve" Checked="ParabolicArc_Checked"
                     MinHeight="25" FontWeight="Bold" Margin="0,10,0,0"/>
        <StackPanel Visibility="{Binding IsParabolicArcSelected, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="{Binding XYFunctionResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Chord-Arc Ratio:"/>
                <Label Content="{Binding PChordArcRatioResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Rise-Span Ratio:"/>
                <Label Content="{Binding RiseSpanRatioResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Vertex Curv.:"/>
                <Label Content="{Binding VertexCurvatureResult}" Width="175"/>
            </StackPanel>
        </StackPanel>

        <RadioButton Content="n-Point Spline" GroupName="Curve" Checked="NPointSpline_Checked"
                     MinHeight="25" FontWeight="Bold" Margin="0,10,0,0"/>
        <StackPanel Visibility="{Binding IsNPointSplineSelected, Converter={StaticResource BoolToVis}}">

            <!-- Algorithm selection -->
            <StackPanel Orientation="Horizontal" Margin="10,4,0,4">
                <RadioButton Content="Catmull-Rom"
                             Style="{StaticResource CheckBoxRadioButton}"
                             GroupName="SplineAlgorithm"
                             IsChecked="{Binding IsCatmullRomSelected, Mode=TwoWay}"
                             Margin="0,0,12,0"/>
                <RadioButton Content="Bézier"
                             Style="{StaticResource CheckBoxRadioButton}"
                             GroupName="SplineAlgorithm"
                             IsChecked="{Binding IsBezierSelected, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Outputs -->
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Turning Angle:"/>
                <Label Content="{Binding TurningAngleResult}" Width="175"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Label Content="Chord-Arc Ratio:"/>
                <Label Content="{Binding SChordArcRatioResult}" Width="175"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>