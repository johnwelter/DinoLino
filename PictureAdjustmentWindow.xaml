<Window x:Class="DinoLino.PictureAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Picture Adjustment"
        MinWidth="360"
        MinHeight="160"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- label column: sizes to widest label -->
            <ColumnDefinition Width="200"/>
            <!-- slider column: fixed width -->
            <ColumnDefinition Width="Auto"/>
            <!-- value column: sizes to content -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Contrast -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Contrast:" VerticalAlignment="Center" Margin="0,0,10,12"/>
        <Slider Grid.Row="0" Grid.Column="1" x:Name="UI_ContrastSlider"
                Minimum="-100" Maximum="100" Value="0"
                TickFrequency="10" IsSnapToTickEnabled="False"
                VerticalAlignment="Center" Margin="0,0,0,12"
                ValueChanged="Contrast_ValueChanged"/>
        <TextBox Grid.Row="0" Grid.Column="2" x:Name="UI_ContrastText" Text="0" Width="45" VerticalAlignment="Center" Margin="10,0,0,12"
                KeyUp="Contrast_KeyUp" LostFocus="Contrast_LostFocus"/>

        <!-- Brightness -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Brightness:" VerticalAlignment="Center" Margin="0,0,10,12"/>
        <Slider Grid.Row="1" Grid.Column="1" x:Name="UI_BrightnessSlider"
                Minimum="-100" Maximum="100" Value="0"
                TickFrequency="10" IsSnapToTickEnabled="False"
                VerticalAlignment="Center" Margin="0,0,0,12"
                ValueChanged="Brightness_ValueChanged"/>
        <TextBox Grid.Row="1" Grid.Column="2" x:Name="UI_BrightnessText" Text="0" Width="45" VerticalAlignment="Center" Margin="10,0,0,12" KeyUp="Brightness_KeyUp" LostFocus="Brightness_LostFocus"/>

        <!-- Saturation -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Saturation:"
                   VerticalAlignment="Center" Margin="0,0,10,16"/>
        <Slider Grid.Row="2" Grid.Column="1" x:Name="UI_SaturationSlider"
                Minimum="-100" Maximum="100" Value="0"
                TickFrequency="10" IsSnapToTickEnabled="False"
                VerticalAlignment="Center" Margin="0,0,0,16"
                ValueChanged="Saturation_ValueChanged"/>
        <TextBox Grid.Row="2" Grid.Column="2" x:Name="UI_SaturationText"
                Text="0" Width="45" VerticalAlignment="Center" Margin="10,0,0,16"
                KeyUp="Saturation_KeyUp" LostFocus="Saturation_LostFocus"/>

        <!-- Close button -->
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                Content="Close" MinWidth="80" HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>