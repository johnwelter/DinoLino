<UserControl x:Class="DinoLino.Utilities.Modes.OutlineControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10,0,10,0">
        <TextBlock Text="Click an object in the image to auto-outline it."
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <TextBlock Text="Tolerance:" FontWeight="Bold"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11"
                   Text="How far from the clicked color a pixel can be and still be included."
                   Margin="0,0,0,2"/>
        <Slider Minimum="5" Maximum="150" Value="{Binding Tolerance}"
                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,2,0,2"/>
        <TextBlock>
            <TextBlock.Text>
                <Binding Path="Tolerance" StringFormat="{}Value: {0:F0}"/>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Text="Gradient Leniency:" FontWeight="Bold" Margin="0,10,0,0"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11"
                   Text="Allows the fill to cross gradual color gradients. Raise if the outline stops short inside an object."
                   Margin="0,0,0,2"/>
        <Slider Minimum="0" Maximum="60" Value="{Binding GradientLeniency}"
                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,2,0,2"/>
        <TextBlock>
            <TextBlock.Text>
                <Binding Path="GradientLeniency" StringFormat="{}Value: {0:F0}"/>
            </TextBlock.Text>
        </TextBlock>
    </StackPanel>
</UserControl>