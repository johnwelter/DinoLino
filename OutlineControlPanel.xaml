<UserControl x:Class="DinoLino.Utilities.Modes.OutlineControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DinoLino.Utilities.Modes">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <local:IntEqualityConverter x:Key="EqualityConverter"/>
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
  </UserControl.Resources>
    
    <StackPanel Margin="10,10,10,0">

        <!-- Draw Outline tool -->
        <RadioButton Content="Draw Outline"
                     GroupName="OutlineTool"
                     IsChecked="{Binding DrawOutlineMode, Mode=TwoWay}"
                     MinHeight="26"/>

      <StackPanel Visibility="{Binding DrawOutlineMode, Converter={StaticResource BoolToVis}}">
        <CheckBox Content="Use Watershed"
                  IsChecked="{Binding UseWatershed, Mode=TwoWay}"
                  Margin="0,6,0,0"
                  ToolTip="More accurate boundaries on complex images, slightly slower"/>

        <CheckBox Content="Multi-Click"
                IsChecked="{Binding MultiClickOutline, Mode=TwoWay}"
                Margin="0,6,0,0"
                ToolTip="First click shows a candidate outline. Click inside to confirm, or outside to expand."/>

          <StackPanel Visibility="{Binding UseWatershed, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="Boundary Sensitivity:" FontWeight="Bold" Margin="0,8,0,0"/>
          <TextBlock TextWrapping="Wrap" Foreground="Gray"
                     Text="Pre-blur reduces noise. Lower sensitivity follows broader boundaries."
                     Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal">
            <RadioButton Content="Off"
                         GroupName="WatershedBlur"
                         IsChecked="{Binding WatershedBlurLevel,
                             Converter={StaticResource EqualityConverter},
                             ConverterParameter=0, Mode=TwoWay}"
                         Margin="0,0,8,0"/>
            <RadioButton Content="Low"
                         GroupName="WatershedBlur"
                         IsChecked="{Binding WatershedBlurLevel,
                             Converter={StaticResource EqualityConverter},
                             ConverterParameter=1, Mode=TwoWay}"
                         Margin="0,0,8,0"/>
            <RadioButton Content="High"
                         GroupName="WatershedBlur"
                         IsChecked="{Binding WatershedBlurLevel,
                             Converter={StaticResource EqualityConverter},
                             ConverterParameter=2, Mode=TwoWay}"/>
          </StackPanel>
        </StackPanel>
        <StackPanel Visibility="{Binding UseWatershed, Converter={StaticResource InverseBoolToVis}}">
          <TextBlock Text="Fill Sensitivity:" FontWeight="Bold" Margin="0,8,0,0"/>
          <TextBlock TextWrapping="Wrap" Foreground="Gray"
                     Text="How aggressively the fill expands from the clicked point."
                     Margin="0,0,0,2"/>
          <Slider Minimum="5" Maximum="150" Value="{Binding FillSensitivity}"
                  TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,2,0,2"/>
          <TextBlock>
            <TextBlock.Text>
              <Binding Path="FillSensitivity" StringFormat="{}Value: {0:F0}"/>
            </TextBlock.Text>
          </TextBlock>
        </StackPanel>
      </StackPanel>

        <!-- Erase Outline tool -->
        <RadioButton Content="Erase Outline"
                     GroupName="OutlineTool"
                     IsChecked="{Binding EraseOutlineMode, Mode=TwoWay}"
                     MinHeight="26"
                     Margin="0,8,0,0"
                     ToolTip="Click and drag over the outline"/>

        <StackPanel Visibility="{Binding EraseOutlineMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Erase Brush Size:" FontWeight="Bold" Margin="0,8,0,0"/>
            <Slider Minimum="5" Maximum="100"
                    Value="{Binding EraseBrushRadius, Mode=TwoWay}"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    Margin="0,2,0,2"/>
            <TextBlock Text="{Binding EraseBrushRadius, StringFormat={}{0:F0} px}"
                       Foreground="Gray" Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Smooth Outline tool -->
        <RadioButton Content="Smooth Outline"
                     GroupName="OutlineTool"
                     IsChecked="{Binding SmoothOutlineMode, Mode=TwoWay}"
                     MinHeight="26"
                     Margin="0,8,0,0"/>

        <StackPanel Visibility="{Binding SmoothOutlineMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Smooth Strength:" FontWeight="Bold" Margin="0,8,0,0"/>
            <Slider Minimum="0" Maximum="20"
                    Value="{Binding SmoothStrength, Mode=TwoWay}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Margin="0,2,0,2"/>
            <TextBlock Text="{Binding SmoothStrength, StringFormat={}{0:F0} passes}"
                       Foreground="Gray" Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Generate Metadata -->
        <RadioButton Content="Generate Metadata"
             GroupName="OutlineTool"
             IsChecked="{Binding OutlineMetadataMode, Mode=TwoWay}"
             MinHeight="26"
             Margin="0,8,0,0"/>

        <StackPanel Visibility="{Binding OutlineMetadataMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Shape Metrics:" FontWeight="Bold" Margin="0,8,0,4"/>

            <!-- Compact summary rows -->
            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Aspect Ratio:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding AspectRatioResult, StringFormat={}{0:F3}}"
                   HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Perimeter / Area:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding PerimeterAreaRatioResult, StringFormat={}{0:F4}}"
                   HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Circularity:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding CircularityResult, StringFormat={}{0:F4}}"
                   HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Solidity:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding SolidityResult, StringFormat={}{0:F4}}"
               HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Sum Turn. Angles:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding SumTurningAnglesResult, StringFormat={}{0:F2}°}"
               HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mean Turn. Angle:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding MeanTurningAngleResult, StringFormat={}{0:F2}°}"
               HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,2,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Turn. Angle Var.:" Foreground="Gray"/>
                <TextBlock Grid.Column="1" Text="{Binding VarianceTurningAnglesResult, StringFormat={}{0:F2}}"
               HorizontalAlignment="Right"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="EFD Harmonics:" Foreground="Gray"/>
                <TextBox x:Name="EfdHarmonicsBox"
                 Width="47"
                 Text="{Binding EfdHarmonics, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                 HorizontalAlignment="Left"
                 HorizontalContentAlignment="Right"
                 Margin="140,0,0,0"/>
            </Grid>

            <!-- EFD detail link -->
            <Button Content="See EFD Coefficients..."
            HorizontalAlignment="Left"
            Background="Transparent"
            BorderThickness="0"
            Foreground="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}"
            Cursor="Hand"
            Padding="0"
            Click="ShowEFDDetails_Click"/>
        </StackPanel>
    </StackPanel>
</UserControl>